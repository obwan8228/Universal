-- ===== Character Visualizer =====
local VisualizerEnabled = false
local VisualizerColor = DefaultColor
local VisualizerParts = {}
local VisualizerConnection

local function clearVisualizer()
    for _, part in ipairs(VisualizerParts) do
        if part and part.Parent then
            part:Destroy()
        end
    end
    VisualizerParts = {}
    if VisualizerConnection then
        VisualizerConnection:Disconnect()
        VisualizerConnection = nil
    end
end

local function createVisualizer(char)
    clearVisualizer()
    if not char then return end

    local partsToVisualize = {}
    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            local acc = v:FindFirstAncestorWhichIsA("Accessory")
            local tool = v:FindFirstAncestorWhichIsA("Tool")
            local ignore = v.Name == "HumanoidRootPart" or v.Name:lower():find("root") or v.Transparency >= 1 or v.Size.Magnitude < 0.5
            if not acc and not tool and not ignore then
                table.insert(partsToVisualize, v)
            end
        end
    end

    for i, v in ipairs(partsToVisualize) do
        local p = Instance.new("Part")
        p.Anchored = true
        p.CanCollide = false
        p.Size = v.Size
        p.Material = Enum.Material.Neon
        p.Color = VisualizerColor
        p.Transparency = 0.55
        p.Name = "VisualizerPart_" .. i
        p.Parent = workspace
        table.insert(VisualizerParts, p)
    end

    local plr = Players.LocalPlayer
    local buffer = {}
    local lerpSpeed = 0.4

    VisualizerConnection = RunService.RenderStepped:Connect(function()
        if not char or not char.Parent then
            clearVisualizer()
            return
        end

        local ping = plr:GetNetworkPing() or 0.1
        local delay = ping
        local snapshot = {}

        for _, v in ipairs(partsToVisualize) do
            if v and v.Parent then
                table.insert(snapshot, v.CFrame)
            end
        end

        table.insert(buffer, {t = tick(), cf = snapshot})
        while #buffer > 0 and tick() - buffer[1].t > delay / 0.5 do
            table.remove(buffer, 1)
        end

        if #buffer > 0 then
            local snapData = buffer[1]
            for i = 1, math.min(#VisualizerParts, #snapData.cf) do
                VisualizerParts[i].CFrame = VisualizerParts[i].CFrame:Lerp(snapData.cf[i], lerpSpeed)
            end
        end
    end)
end

local function toggleVisualizer(state)
    VisualizerEnabled = state
    if state then
        if LP.Character then createVisualizer(LP.Character) end
    else
        clearVisualizer()
    end
end

