-- ===== Enable Crosshair Toggle =====
MiscSection:Toggle({
    Name = "Enable Crosshair",
    Flag = "EnableCrosshair",
    Default = false,
    Callback = function(Value)
        local RunService = game:GetService("RunService")
        local Camera = workspace.CurrentCamera
        local UIS = game:GetService("UserInputService")

        if not Value then
            if _G.CrosshairConnection then
                _G.CrosshairConnection:Disconnect()
                _G.CrosshairConnection = nil
            end
            if _G.CrosshairObjects then
                for _, obj in ipairs(_G.CrosshairObjects) do
                    pcall(function() obj:Remove() end)
                end
                _G.CrosshairObjects = nil
            end
            return
        end

        -- Create crosshair visuals
        local CrosshairLines, LineCount = {}, 4
        local resizeAngle, spinAngle = 0, 0

        for i = 1, LineCount do
            local line = Drawing.new("Line")
            line.Color = crosshairSettings.LineColor
            line.Thickness = crosshairSettings.LineThickness
            line.Visible = true
            table.insert(CrosshairLines, line)
        end

        local Dot = Drawing.new("Circle")
        Dot.Radius = crosshairSettings.DotRadius
        Dot.Color = crosshairSettings.DotColor
        Dot.Filled = true
        Dot.Visible = true

        local LeftText = Drawing.new("Text")
        LeftText.Text = "Ban"
        LeftText.Size = 16
        LeftText.Center = true
        LeftText.Outline = true
        LeftText.Color = Color3.new(1,1,1)
        LeftText.Visible = crosshairSettings.ShowWatermark
        LeftText.Font = 2

        local RightText = Drawing.new("Text")
        RightText.Text = ".me"
        RightText.Size = 16
        RightText.Center = true
        RightText.Outline = true
        RightText.Color = crosshairSettings.LineColor
        RightText.Visible = crosshairSettings.ShowWatermark
        RightText.Font = 2

        -- Update loop
        local lastTime = tick()
        _G.CrosshairConnection = RunService.RenderStepped:Connect(function()
            local deltaTime = tick() - lastTime
            lastTime = tick()

            local Center
            if crosshairSettings.PositionMode == "Cursor" then
                local mouse = UIS:GetMouseLocation()
                Center = Vector2.new(mouse.X, mouse.Y)
            else
                Center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            end

            -- Resize pulse effect
            local extraLength = 0
            if crosshairSettings.ResizeEnabled then
                resizeAngle += deltaTime * crosshairSettings.ResizeSpeed
                extraLength = math.sin(resizeAngle) * crosshairSettings.ResizeAmount
            end

            -- Update lines
            for i, line in ipairs(CrosshairLines) do
                line.Visible = not crosshairSettings.DotOnly
                local a = math.rad(spinAngle) + (math.pi*2/LineCount)*(i-1)
                local from = Vector2.new(Center.X + math.cos(a)*crosshairSettings.GapSize,
                                         Center.Y + math.sin(a)*crosshairSettings.GapSize)
                local to = Vector2.new(Center.X + math.cos(a)*(crosshairSettings.GapSize + crosshairSettings.LineLength + extraLength),
                                       Center.Y + math.sin(a)*(crosshairSettings.GapSize + crosshairSettings.LineLength + extraLength))
                line.From = from
                line.To = to
                line.Color = crosshairSettings.LineColor
                line.Thickness = crosshairSettings.LineThickness
            end

            -- Dot
            Dot.Position = Center
            Dot.Color = crosshairSettings.DotColor
            Dot.Radius = crosshairSettings.DotRadius

            -- Watermark
            LeftText.Position = Vector2.new(Center.X - 12, Center.Y + 20)
            RightText.Position = Vector2.new(Center.X + 14, Center.Y + 20)
            LeftText.Visible = crosshairSettings.ShowWatermark
            RightText.Visible = crosshairSettings.ShowWatermark
            RightText.Color = crosshairSettings.LineColor

            -- Spin rotation
            if crosshairSettings.SpinEnabled then
                spinAngle = (spinAngle + (crosshairSettings.SpinSpeed * 36 * deltaTime)) % 360
            end
        end)

        -- Store for cleanup
        _G.CrosshairObjects = {Dot, LeftText, RightText}
        for _, line in ipairs(CrosshairLines) do
            table.insert(_G.CrosshairObjects, line)
        end
    end
})

