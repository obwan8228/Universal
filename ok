local function createParticle(pos)
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, 6, 0, 6)
    particle.AnchorPoint = Vector2.new(0.5, 0.5)
    particle.Position = UDim2.new(0, pos.X, 0, pos.Y)
    particle.BackgroundColor3 = Color3.fromRGB(166, 147, 243)
    particle.BorderSizePixel = 0
    particle.Parent = Button
    local tween = TweenService:Create(particle, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, pos.X + math.random(-30, 30), 0, pos.Y + math.random(-30, 30)),
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1
    })
    tween:Play()
    tween.Completed:Connect(function() particle:Destroy() end)
end

local function animatePress(pos)
    local shrink = TweenService:Create(Button, TweenInfo.new(0.15, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = UDim2.new(0, 34, 0, 34)})
    local expand = TweenService:Create(Button, TweenInfo.new(0.2, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {Size = UDim2.new(0, 40, 0, 40)})
    local glowIn = TweenService:Create(Glow, TweenInfo.new(0.15, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Transparency = 0})
    local glowOut = TweenService:Create(Glow, TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Transparency = 0.5})
    glowIn:Play()
    shrink:Play()
    for i = 1, 10 do
        createParticle(pos)
    end
    shrink.Completed:Connect(function()
        expand:Play()
        glowOut:Play()
    end)
end

local dragging = false
local dragInput, dragStart, startPos
local targetPos = Button.Position

Button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragStart = input.Position
        startPos = Button.Position
        dragging = false
        dragInput = input
        local relativePos = Vector2.new(input.Position.X - Button.AbsolutePosition.X, input.Position.Y - Button.AbsolutePosition.Y)
        bool = not bool
        animatePress(relativePos)
        if Window then Window:SetOpen(bool) end
    end
end)

Button.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
        dragging = true
    end
end)

local function update(input)
    local delta = input.Position - dragStart
    targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

RunService.RenderStepped:Connect(function()
    if dragging and dragInput then
        update(dragInput)
        Button.Position = Button.Position:Lerp(targetPos, 0.2)
    end
end)

