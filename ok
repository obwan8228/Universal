-- Aimbot toggle
AimbotSection:Toggle({
    Name = "Enable Aim Assist",
    Flag = "EnableAimbot",
    Default = false,
    Callback = function(Value)
        Aimbot.Enabled = Value

        if Value then
            DrawFOV = Drawing.new("Circle")
            DrawOutline = Drawing.new("Circle")
            DrawSnap = Drawing.new("Line")

            Connection = RunService.RenderStepped:Connect(function(dt)
                local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
                local fov = Aimbot.FOV

                -- FOV visuals
                if Aimbot.ShowFOV then
                    DrawFOV.Position = center
                    DrawFOV.Radius = fov
                    DrawFOV.Color = Aimbot.FOVFillColor
                    DrawFOV.Filled = true
                    DrawFOV.Transparency = 0.25
                    DrawFOV.Thickness = 1
                    DrawFOV.Visible = true

                    DrawOutline.Position = center
                    DrawOutline.Radius = fov
                    DrawOutline.Color = Aimbot.FOVOutlineColor
                    DrawOutline.Filled = false
                    DrawOutline.Thickness = 2
                    DrawOutline.Visible = true
                else
                    DrawFOV.Visible = false
                    DrawOutline.Visible = false
                end

                -- Find closest target
                local closest, bestDist = nil, Aimbot.FOV
                for _, pl in ipairs(Players:GetPlayers()) do
                    if pl ~= LocalPlayer and pl.Character and pl.Character.Parent and pl.Character:FindFirstChildOfClass("Humanoid") then
                        local hum = pl.Character:FindFirstChildOfClass("Humanoid")
                        if hum and hum.Health > 0 then
                            if Aimbot.IgnoreFriends and LocalPlayer:IsFriendsWith(pl.UserId) then
                            elseif Aimbot.TeamCheck and LocalPlayer.Team and pl.Team and (LocalPlayer.Team == pl.Team) then
                            else
                                local targetPart = pl.Character:FindFirstChild(Aimbot.TargetPart)
                                if targetPart and isVisible(targetPart) then
                                    local pos, on = Camera:WorldToViewportPoint(targetPart.Position)
                                    if on then
                                        local mag = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                                        if mag < bestDist then
                                            bestDist = mag
                                            closest = {player = pl, part = targetPart}
                                        end
                                    end
                                end
                            end
                        end
                    end
                end

                AimTarget = closest

                -- Snaplines
                if Aimbot.Snaplines and AimTarget and AimTarget.part then
                    local tgtPos, on = Camera:WorldToViewportPoint(AimTarget.part.Position)
                    if on then
                        DrawSnap.From = center
                        DrawSnap.To = Vector2.new(tgtPos.X, tgtPos.Y)
                        DrawSnap.Color = Color3.fromRGB(119,120,255)
                        DrawSnap.Thickness = 2
                        DrawSnap.Visible = true
                    else
                        DrawSnap.Visible = false
                    end
                else
                    if DrawSnap then DrawSnap.Visible = false end
                end

                -- Smooth aim
                if AimTarget and AimTarget.part then
                    local targetCFrame = CFrame.new(Camera.CFrame.Position, AimTarget.part.Position)
                    local speedFactor = math.clamp(dt * (Aimbot.Smoothness*5), 0, 1)
                    Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, speedFactor)
                end
            end)
        else
            if Connection then Connection:Disconnect() Connection = nil end
            if DrawFOV then DrawFOV:Remove() DrawFOV = nil end
            if DrawOutline then DrawOutline:Remove() DrawOutline = nil end
            if DrawSnap then DrawSnap:Remove() DrawSnap = nil end
            AimTarget = nil
        end
    end
})

