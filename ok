    for _, part in ipairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            savePartProps(part)
            part.Material = Enum.Material.ForceField
            part.Color = FFCharColor
            part.Transparency = 0.35
            part.Reflectance = 0
        end
    end
end

