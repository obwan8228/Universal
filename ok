local ChinaHatEnabled = false
local ChinaHatAccessories = {}
local ChinaHatColor = DefaultColor

local function addChinaHat(character)
    task.wait(1)
    if not ChinaHatEnabled then return end

    local HeadAccessories = {1033722, 0} -- example
    local TorsoAccessories = {0}

    local function weldParts(part0, part1, c0, c1)
        local weld = Instance.new("Weld")
        weld.Part0 = part0
        weld.Part1 = part1
        weld.C0 = c0 or CFrame.new()
        weld.C1 = c1 or CFrame.new()
        weld.Parent = part0
        return weld
    end

    local function findAttachment(rootPart, name)
        for _, d in pairs(rootPart:GetDescendants()) do
            if d:IsA("Attachment") and d.Name == name then return d end
        end
    end

    local function addAccessoryToCharacter(accessoryId, parentPart)
        if not ChinaHatEnabled then return end
        local success, accessory = pcall(function()
            return game:GetObjects("rbxassetid://"..tostring(accessoryId))[1]
        end)
        if not success or not accessory then return end
        accessory.Parent = character
        table.insert(ChinaHatAccessories, accessory)

        local handle = accessory:FindFirstChild("Handle")
        if handle then
            handle.Material = Enum.Material.ForceField
            handle.Color = ChinaHatColor
            handle.Transparency = 0.3
            handle.Reflectance = 0
            handle.CanCollide = false
            handle.Anchored = false

            local highlight = Instance.new("Highlight")
            highlight.Adornee = handle
            highlight.FillColor = ChinaHatColor
            highlight.FillTransparency = 0.5
            highlight.OutlineColor = ChinaHatColor
            highlight.OutlineTransparency = 0
            highlight.Parent = handle

            local attachment = handle:FindFirstChildOfClass("Attachment")
            if attachment then
                local parentAttachment = findAttachment(parentPart, attachment.Name)
                if parentAttachment then
                    weldParts(parentPart, handle, parentAttachment.CFrame, attachment.CFrame)
                else
                    weldParts(parentPart, handle, CFrame.new(), CFrame.new())
                end
            else
                weldParts(parentPart, handle, CFrame.new(0,0,0), CFrame.new())
            end
        end
    end

    -- Remove old
    for _, acc in ipairs(ChinaHatAccessories) do
        if acc.Parent then acc:Destroy() end
    end
    ChinaHatAccessories = {}

    for _, id in ipairs(HeadAccessories) do addAccessoryToCharacter(id, character:FindFirstChild("Head")) end
    for _, id in ipairs(TorsoAccessories) do
        local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
        if torso then addAccessoryToCharacter(id, torso) end
    end
end

local function removeChinaHat()
    for _, acc in ipairs(ChinaHatAccessories) do
        if acc.Parent then acc:Destroy() end
    end
    ChinaHatAccessories = {}
end

